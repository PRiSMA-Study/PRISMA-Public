    WEIGHT_PERES = ifelse (WEIGHT_PERES < 0, NA, WEIGHT_PERES)
    )%>% 
  
  select(MOMID, PREGID, SITE, TYPE_VISIT, ANT_PEDAT, WEIGHT_PERES, WEIGHT_PEPERF)


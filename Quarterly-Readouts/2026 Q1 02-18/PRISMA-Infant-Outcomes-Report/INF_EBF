  #In order not to lose the dates, when these was taken
  #Create function to get the dates by PNC visits
  get_pnc_visit_date <- function(data, visit_range, new_colname) {
    data %>%
      filter(TYPE_VISIT %in% visit_range) %>%
      group_by(SITE, MOMID, PREGID, INFANTID) %>%
      summarise(
        !!new_colname := if (all(is.na(VISIT_DATE))) {
          NA
        } else {
          max(VISIT_DATE, na.rm = TRUE)  # most recent visit date in that window
        },
        .groups = "drop"
      )
  }
  
  pnc0_dates  <- get_pnc_visit_date(mat_ebf, 6:7,  "VISIT_DATE_PNC0")
  pnc1_dates  <- get_pnc_visit_date(mat_ebf, 6:8,  "VISIT_DATE_PNC1")
  pnc4_dates  <- get_pnc_visit_date(mat_ebf, 6:9,  "VISIT_DATE_PNC4")
  pnc6_dates  <- get_pnc_visit_date(mat_ebf, 6:10, "VISIT_DATE_PNC6")
  pnc26_dates <- get_pnc_visit_date(mat_ebf, 6:11, "VISIT_DATE_PNC26")
  pnc52_dates <- get_pnc_visit_date(mat_ebf, 6:12, "VISIT_DATE_PNC52")
  
#join EBF (wide) + NOT-EBF (wide) onto the per-visit data 
  inf_ebf_wide <- mat_ebf_df %>%
    distinct(SITE, MOMID, PREGID, INFANTID, .keep_all = TRUE) %>%

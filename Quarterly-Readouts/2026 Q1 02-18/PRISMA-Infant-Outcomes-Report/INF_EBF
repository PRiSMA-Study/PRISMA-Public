# function to summarise NOT-EBF info up to a visit range 
summarise_not_ebf <- function(data, visit_range, suffix) {
  
  clean_codes <- function(vec) {
    # vec = character vector like c("1,2", "55", "77", "0")
    
    # extract individual codes
    codes <- unique(unlist(str_split(vec, ",")))
    codes <- codes[codes != ""]
    
    # Case 1: all values missing (55, 77)
    if (all(codes %in% c("55", "77"))) {
      return("55")
    }
    
    # Remove 55 and 77 if ANY real codes exist
    real_codes <- codes[codes %in% c("1","2","3","4","5","6","7","8","9","88")]
    
    if (length(real_codes) > 0) {
      return(paste(sort(real_codes), collapse = ","))
    }
    
    # Case 2: all zero or empty
    if (all(codes %in% c("0"))) {
      return("0")
    }
    
    # Fallback (should not be needed)
    return("0")
  }
  
  data %>% 
    filter(TYPE_VISIT %in% visit_range) %>%
    group_by(SITE, MOMID, PREGID, INFANTID) %>%
    summarise(
      # ---- FOODS ----
      NOT_EBF_FOODS_tmp = {
        v <- NOT_EBF_FOODS[!is.na(NOT_EBF_FOODS)]
        clean_codes(v)
      },
      
      # ---- REASONS ----
      NOT_EBF_REASON_tmp = {
        v <- NOT_EBF_REASON[!is.na(NOT_EBF_REASON)]
        clean_codes(v)
      },
      
      # ---- other-food specify ----
      NOT_EBF_OTHER_FOOD_SPFY_tmp = {
        txt <- NOT_EBF_OTHER_FOOD_SPFY[
          !is.na(NOT_EBF_OTHER_FOOD_SPFY) &
            NOT_EBF_OTHER_FOOD_SPFY != "not_applicable" &
            NOT_EBF_OTHER_FOOD_SPFY != ""
        ]
        txt <- unique(txt)
        if (length(txt) == 0) NA_character_ else paste(txt, collapse = "; ")
      },
      
      # ---- other-reason specify ----
      NOT_EBF_OTHER_RSN_SPFY_tmp = {
        txt <- NOT_EBF_OTHER_RSN_SPFY[
          !is.na(NOT_EBF_OTHER_RSN_SPFY) &
            NOT_EBF_OTHER_RSN_SPFY != "not_applicable" &
            NOT_EBF_OTHER_RSN_SPFY != ""
        ]
        txt <- unique(txt)
        if (length(txt) == 0) NA_character_ else paste(txt, collapse = "; ")
      },
      
      .groups = "drop"
    ) %>%
    rename(
      !!paste0("NOT_EBF_FOODS_", suffix) := NOT_EBF_FOODS_tmp,
      !!paste0("NOT_EBF_REASON_", suffix) := NOT_EBF_REASON_tmp,
      !!paste0("NOT_EBF_OTHER_FOOD_SPFY_", suffix) := NOT_EBF_OTHER_FOOD_SPFY_tmp,
      !!paste0("NOT_EBF_OTHER_RSN_SPFY_", suffix) := NOT_EBF_OTHER_RSN_SPFY_tmp
    )
}

  
  # make the wide NOT-EBF summaries for the all visit windows

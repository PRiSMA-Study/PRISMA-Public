# Function to calculate EBF status for a given TYPE_VISIT range ----
# Function to calculate EBF status and which TYPE_VISIT breaks EBF
calculate_ebf <- function(data, visit_range, new_colname, new_visits_colname) {
  data %>%
    filter(TYPE_VISIT %in% visit_range) %>%
    group_by(MOMID, PREGID, INFANTID, SITE) %>%
    summarise(
      non_missing = sum(!is.na(BRSTFEED_EXCL_FAORRES)),
      any_zero    = any(BRSTFEED_EXCL_FAORRES == 0, na.rm = TRUE),
      all_ones    = all(BRSTFEED_EXCL_FAORRES == 1, na.rm = TRUE),
      # list of TYPE_VISITs where EBF is 0 in this range
      visits_zero = paste(
        sort(unique(TYPE_VISIT[BRSTFEED_EXCL_FAORRES == 0])),
        collapse = ","
      ),
      .groups = "drop"
    ) %>%
    mutate(
      !!new_colname := case_when(
        non_missing == 0 ~ 55,   # no info in this window
        any_zero ~ 0,            # at least one non-EBF
        all_ones ~ 1,            # all visits EBF
        TRUE ~ 1                 # fallback (shouldn't really hit if coded cleanly)
      ),
      # only keep the list of visits if EBF == 0; otherwise NA
      !!new_visits_colname := ifelse(
        !!rlang::sym(new_colname) == 0 & visits_zero != "",
        visits_zero,
        NA_character_
      )
    ) %>%
    select(SITE, MOMID, PREGID, INFANTID, !!rlang::sym(new_colname), !!rlang::sym(new_visits_colname))
}


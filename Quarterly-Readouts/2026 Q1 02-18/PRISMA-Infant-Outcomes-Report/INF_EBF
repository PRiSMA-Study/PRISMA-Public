    left_join(pnc0_dates,  by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(pnc1_dates,  by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(pnc4_dates,  by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(pnc6_dates,  by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(pnc26_dates, by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(pnc52_dates, by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(ebf_6_7,  by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(ebf_6_8,  by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(ebf_6_9,  by = c("SITE","MOMID","PREGID","INFANTID")) %>%

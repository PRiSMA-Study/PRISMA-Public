# Combined variable: NOT_EBF_FOODS 
# List which food codes (1,2,3,4,5,6,88) are present (==1).
# Returns "0" if none are 1, otherwise a comma-separated list like "1,2,88".
food_cols <- c("INFANT_FOODS_FAORRES_1",
               "INFANT_FOODS_FAORRES_2",
               "INFANT_FOODS_FAORRES_3",
               "INFANT_FOODS_FAORRES_4",
               "INFANT_FOODS_FAORRES_5",
               "INFANT_FOODS_FAORRES_6",
               "INFANT_FOODS_FAORRES_88")

food_codes <- c("1", "2", "3", "4", "5", "6", "88")

inf_mnh13$NOT_EBF_FOODS <- apply(
  inf_mnh13[, food_cols],
  1,
  function(x) {
    
    # Convert everything except 1,0 to 77
    x_clean <- case_when(x == 1 ~ 1, x == 0 ~ 0, TRUE ~ 77)
    
    # Rule 1: Any 1 → return list
    if (any(x_clean == 1, na.rm = TRUE)) {
      codes <- food_codes[x_clean == 1]
      return(paste(codes, collapse = ","))
    }
    
    # Rule 2: All 77 → return "77"
    if (all(x_clean == 77)) {
      return("77")
    }
    
    # Rule 3: No 1; all values are 0 or 77 → return "0"
    if (all(x_clean %in% c(0,77))) {
      return("0")
    }
    
    # Fallback (should not occur)
    return("0")
  }
)



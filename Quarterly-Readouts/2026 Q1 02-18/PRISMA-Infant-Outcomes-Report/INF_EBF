    left_join(ebf_6_12, by = c("SITE","MOMID","PREGID","INFANTID")) %>%
     # add wide NOT-EBF summaries
    left_join(not_ebf_6_7, by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(not_ebf_6_8, by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(not_ebf_6_9, by = c("SITE","MOMID","PREGID","INFANTID"))%>%
    left_join(not_ebf_6_10, by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(not_ebf_6_11, by = c("SITE","MOMID","PREGID","INFANTID")) %>%
    left_join(not_ebf_6_12, by = c("SITE","MOMID","PREGID","INFANTID")) 
 
   #Replace empty variables with 55 
